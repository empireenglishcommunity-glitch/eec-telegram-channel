# Raw and curated training images — large binaries, not portable, don't belong in git
dataset/raw_seed/
dataset/curated/

# Model weights and checkpoints — large binaries, download via scripts instead
models/
*.safetensors
*.ckpt
*.pt

# Trained LoRA outputs (until reviewed and deliberately promoted)
training/output/

# Generated output images (final brand content — sync to storage, not git)
output/

# Zipped dataset handoff artifact — regenerate via prepare_dataset.py + zip, not tracked
dataset/curated_dataset.zip

# Run logs / raw prompt dumps — ephemeral, not source
dataset/seed_batch_run.log
dataset/seed_prompts_output.txt

# Downloaded checkpoint sample previews used for manual quality review during
# training — diagnostic scratch images, not a deliverable. Findings from
# reviewing these are written up in text in PROGRESS.md / commit messages.
training/checkpoint_previews/

# Python
__pycache__/
*.pyc
.ipynb_checkpoints/
